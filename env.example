# Скопируйте в .env и заполните реальными значениями. .env в git НЕ коммитить.
API_KEY=<ваш-ключ-основного-провайдера>
API_URL=https://api.agentplatform.ru/v1/chat/completions
MODEL=google/gemini-2.5-flash-lite
MAX_TOKENS_PER_CALL=12000
MAX_CONTEXT_CHARS=500000

# Резервный провайдер (fallback при 429/5xx)
FALLBACK_API_KEY=<ключ-резервного-провайдера>
FALLBACK_API_URL=https://api.timeweb.ai/v1/chat/completions
FALLBACK_MODEL=gemini/gemini-2.5-flash-lite

# Первичный админ при пустой БД (если не задан — сгенерируется случайный, см. лог старта)
ADMIN_INITIAL_LOGIN=admin
ADMIN_INITIAL_PASSWORD=<надёжный-пароль>

# Включить Swagger /docs (только для отладки; в проде не задавать)
# ENABLE_DOCS=1
